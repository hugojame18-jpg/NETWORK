// CC Submit — Affiliate Network Platform
// Prisma schema: single source of truth for the relational data model.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  PUBLISHER
  ADVERTISER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum OfferStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PayoutType {
  CPA
  CPL
  CPS
  REVSHARE
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  ALL
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum ConversionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum PaymentStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum PaymentMethod {
  PAYPAL
  BANK_WIRE
  CRYPTO
  PAYONEER
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  PAYMENT
  CONVERSION
  OFFER
}

enum PublisherApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---------------------------------------------------------------------------
// Identity, auth & RBAC
// ---------------------------------------------------------------------------

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  name            String
  image           String?
  role            UserRole
  status          UserStatus @default(PENDING)
  emailVerified   DateTime?
  twoFactorSecret String?

  publisher  Publisher?
  advertiser Advertiser?

  permissions         UserPermission[]
  notifications       Notification[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  sessions            Session[]
  enteredDailyStats   PublisherDailyStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique // e.g. "offers.approve", "payments.review"
  description String

  users UserPermission[]

  createdAt DateTime @default(now())
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, permissionId])
}

// ---------------------------------------------------------------------------
// Publisher / Advertiser profiles
// ---------------------------------------------------------------------------

model Publisher {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Short, human-readable sequential affiliate number (e.g. #1000) for easy
  // identification in the admin. Auto-assigned by the DB on creation.
  memberId Int @unique @default(autoincrement())

  companyName       String?
  website           String?
  trafficSources    String[]
  applicationStatus PublisherApplicationStatus @default(PENDING)

  // Loyalty / referral. `referralCode` is a short, human-shareable code (see
  // generateReferralCode). Nullable so this additive migration needs no upfront
  // backfill — it's lazily ensured the first time a publisher opens the rewards
  // page. `referredBy` is the affiliate who referred this one (self-relation);
  // SetNull on delete so removing a parent account doesn't cascade-delete its
  // referrals.
  referralCode String?     @unique
  referredById String?
  referredBy   Publisher?  @relation("PublisherReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    Publisher[] @relation("PublisherReferrals")

  paymentMethod  PaymentMethod?
  paymentDetails Json?

  balance     Decimal @default(0) @db.Decimal(12, 2)
  totalEarned Decimal @default(0) @db.Decimal(12, 2)
  minPayout   Decimal @default(50) @db.Decimal(12, 2)

  affiliateLinks AffiliateLink[]
  clicks         Click[]
  leads          Lead[]
  conversions    Conversion[]
  commissions    Commission[]
  payments       Payment[]
  dailyStats     PublisherDailyStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationStatus])
  @@index([referredById])
}

model Advertiser {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String
  website     String?

  totalSpent Decimal @default(0) @db.Decimal(12, 2)

  campaigns Campaign[]
  offers    Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Campaigns & Offers
// ---------------------------------------------------------------------------

model Campaign {
  id           String     @id @default(cuid())
  advertiserId String
  advertiser   Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  budget      Decimal?       @db.Decimal(12, 2)
  spent       Decimal        @default(0) @db.Decimal(12, 2)
  startDate   DateTime?
  endDate     DateTime?

  offers Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advertiserId])
  @@index([status])
}

model Offer {
  id           String     @id @default(cuid())
  advertiserId String
  advertiser   Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  campaignId   String?
  campaign     Campaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  name        String
  slug        String      @unique
  description String
  category    String
  status      OfferStatus @default(PENDING)

  payout     Decimal    @db.Decimal(12, 2)
  payoutType PayoutType @default(CPA)
  currency   String     @default("USD")

  countries    String[] // ISO country codes, empty = worldwide
  devices      DeviceType[]
  restrictions String?

  creativeUrl String?
  landingUrl  String
  previewUrl  String?
  cookieDays  Int     @default(30)
  dailyCap    Int?

  affiliateLinks AffiliateLink[]
  clicks         Click[]
  leads          Lead[]
  conversions    Conversion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([advertiserId])
  @@index([status])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Tracking: links, clicks, leads, conversions, commissions
// ---------------------------------------------------------------------------

model AffiliateLink {
  id          String    @id @default(cuid())
  token       String    @unique // opaque tracking token used in the public URL
  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  offerId     String
  offer       Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)

  label      String?
  subId      String?
  clickCount Int     @default(0)

  clicks Click[]
  leads  Lead[]

  createdAt DateTime @default(now())

  @@unique([publisherId, offerId, subId])
  @@index([publisherId])
  @@index([offerId])
}

model Click {
  id          String        @id @default(cuid())
  linkId      String
  link        AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  publisherId String
  publisher   Publisher     @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  offerId     String
  offer       Offer         @relation(fields: [offerId], references: [id], onDelete: Cascade)

  cookieId  String     @unique
  ipHash    String
  userAgent String
  device    DeviceType @default(ALL)
  browser   String?
  os        String?
  country   String?
  referrer  String?
  subId     String?

  isFraud     Boolean @default(false)
  fraudReason String?

  leads Lead[]

  createdAt DateTime @default(now())

  @@index([publisherId, createdAt])
  @@index([offerId, createdAt])
  @@index([ipHash, createdAt])
  @@index([linkId])
}

model Lead {
  id          String        @id @default(cuid())
  clickId     String        @unique
  click       Click         @relation(fields: [clickId], references: [id], onDelete: Cascade)
  linkId      String
  link        AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  offerId     String
  offer       Offer         @relation(fields: [offerId], references: [id], onDelete: Cascade)
  publisherId String
  publisher   Publisher     @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  payload Json?
  status  ConversionStatus @default(PENDING)

  conversion Conversion?

  createdAt DateTime @default(now())

  @@index([publisherId, createdAt])
  @@index([offerId, createdAt])
}

model Conversion {
  id          String    @id @default(cuid())
  leadId      String    @unique
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  offerId     String
  offer       Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  payout Decimal          @db.Decimal(12, 2)
  status ConversionStatus @default(PENDING)

  commission Commission?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publisherId, createdAt])
  @@index([offerId, createdAt])
  @@index([status])
}

model Commission {
  id           String     @id @default(cuid())
  conversionId String     @unique
  conversion   Conversion @relation(fields: [conversionId], references: [id], onDelete: Cascade)
  publisherId  String
  publisher    Publisher  @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  amount Decimal          @db.Decimal(12, 2)
  status CommissionStatus @default(PENDING)

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publisherId, createdAt])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Manually-entered daily statistics
//
// The automated tracking engine (Click/Lead/Conversion/Commission above)
// stays in place, but the numbers shown to publishers are NOT computed from
// it: the admin enters one row per publisher per day (clicks, hosts,
// conversions, revenue) and that row is the only source of truth the
// publisher dashboard reads from.
// ---------------------------------------------------------------------------

model PublisherDailyStat {
  id          String    @id @default(cuid())
  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  date        DateTime @db.Date // calendar day only — a plain DATE column sidesteps
  // the "timestamp without time zone" footgun where the DB session's
  // timezone silently shifts midnight by a few hours on write/read.
  clicks      Int      @default(0)
  hosts       Int      @default(0)
  conversions Int      @default(0)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)

  enteredById String?
  enteredBy   User?    @relation(fields: [enteredById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([publisherId, date])
  @@index([publisherId, date])
  @@index([date])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model Payment {
  id          String    @id @default(cuid())
  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  amount Decimal       @db.Decimal(12, 2)
  method PaymentMethod
  status PaymentStatus @default(PENDING)
  note   String?

  commissions Commission[]

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
  paidAt      DateTime?

  @@index([publisherId, status])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Notifications, settings, audit
// ---------------------------------------------------------------------------

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  NotificationType @default(INFO)
  title String
  body  String
  read  Boolean          @default(false)
  link  String?

  createdAt DateTime @default(now())

  @@index([userId, read])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id      String  @id @default(cuid())
  actorId String?
  actor   User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  action     String // e.g. "publisher.suspend", "offer.approve"
  targetType String // e.g. "User", "Offer", "Payment"
  targetId   String?
  metadata   Json?
  ipHash     String?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}
